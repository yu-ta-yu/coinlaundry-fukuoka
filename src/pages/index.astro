---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const stores = [
  {
    name: "せんたく広場すせんじ",
    area: "西区・周船寺エリア",
    futon: "○",
    capacity: "25kg",
    hours: "24時間営業",
  },
  {
    name: "Baluko Laundry Place 姪浜",
    area: "西区・姪浜エリア",
    futon: "○",
    capacity: "27kg",
    hours: "24時間営業",
  },
  {
    name: "Baluko Laundry Place 福岡今川",
    area: "中央区・今川エリア",
    futon: "○",
    capacity: "大型",
    hours: "24時間営業",
  },
  {
    name: "ランドリープレス博多住吉店",
    area: "博多区・住吉エリア",
    futon: "○",
    capacity: "洗濯35kg／乾燥27kg",
    hours: "24時間営業",
  },
  {
    name: "ランドリープレス警固店",
    area: "中央区・警固エリア",
    futon: "○",
    capacity: "大型",
    hours: "24時間営業",
  },
];

const articles = (await getCollection("articles")).sort((a, b) =>
  a.data.type === "pillar" ? -1 : b.data.type === "pillar" ? 1 : 0
);
---
<BaseLayout title="福岡コインランドリー設備比較｜容量・布団対応・営業時間がわかる">
  <h1>福岡市のコインランドリーを「設備」で比較できるサイト</h1>

  <p>
    「布団が洗える大型機はどこにある？」「深夜でも使える店舗は？」——
    このサイトは、福岡市内のコインランドリー5店舗を実際に調査し、
    洗濯機・乾燥機の容量、布団対応、営業時間といった<strong>設備情報を横断比較</strong>できるようにまとめています。
  </p>

  <h2>掲載店舗一覧</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>店舗名</th>
          <th>エリア</th>
          <th>布団丸洗い</th>
          <th>最大容量目安</th>
          <th>営業時間</th>
        </tr>
      </thead>
      <tbody>
        {stores.map((s) => (
          <tr>
            <td>{s.name}</td>
            <td>{s.area}</td>
            <td>{s.futon}</td>
            <td>{s.capacity}</td>
            <td>{s.hours}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="coming-soon">
    ※ 営業時間・料金は変更される場合があります。利用前に各店舗の公式サイトで最新情報をご確認ください。
  </p>

  <h2>比較記事</h2>
  <ul>
    {articles.map((a) => (
      <li>
        <a href={`/articles/${a.slug}`}>{a.data.title}</a>
      </li>
    ))}
  </ul>

  <h2>このサイトについて</h2>
  <p>
    福岡市在住の運営者が、実際に店舗を訪問して設備を確認したうえで情報をまとめています。
    料金・営業時間などの可変情報は変更される場合があるため、利用前に各店舗の公式サイトで最新情報をご確認ください。
  </p>
</BaseLayout>
