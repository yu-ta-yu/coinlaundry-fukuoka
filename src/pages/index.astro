---
import BaseLayout from "../layouts/BaseLayout.astro";

const stores = [
  {
    name: "せんたく広場すせんじ",
    area: "西区・周船寺エリア",
    futon: "[要確認]",
    hours: "[要確認]",
  },
  {
    name: "Baluko Laundry Place 姪浜",
    area: "西区・姪浜エリア",
    futon: "[要確認]",
    hours: "[要確認]",
  },
  {
    name: "Baluko Laundry Place 福岡今川",
    area: "中央区・今川エリア",
    futon: "[要確認]",
    hours: "[要確認]",
  },
  {
    name: "ランドリープレス博多住吉店",
    area: "博多区・住吉エリア",
    futon: "[要確認]",
    hours: "[要確認]",
  },
  {
    name: "ランドリープレス警固店",
    area: "中央区・警固エリア",
    futon: "[要確認]",
    hours: "[要確認]",
  },
];

const articles = [
  { title: "福岡市コインランドリー設備比較 完全ガイド", status: "近日公開" },
  { title: "布団丸洗いに対応した福岡市のコインランドリー比較", status: "近日公開" },
  { title: "24時間営業で使える天神・博多エリアのコインランドリー", status: "近日公開" },
];
---
<BaseLayout title="福岡コインランドリー設備比較｜容量・布団対応・営業時間がわかる">
  <h1>福岡市のコインランドリーを「設備」で比較できるサイト</h1>

  <p>
    「布団が洗える大型機はどこにある？」「深夜でも使える店舗は？」——
    このサイトは、福岡市内のコインランドリー5店舗を実際に調査し、
    洗濯機・乾燥機の容量、布団対応、営業時間といった<strong>設備情報を横断比較</strong>できるようにまとめています。
  </p>

  <h2>掲載店舗一覧</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>店舗名</th>
          <th>エリア</th>
          <th>布団対応</th>
          <th>営業時間</th>
        </tr>
      </thead>
      <tbody>
        {stores.map((s) => (
          <tr>
            <td>{s.name}</td>
            <td>{s.area}</td>
            <td>{s.futon}</td>
            <td>{s.hours}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="coming-soon">
    ※ 表内の詳細データは各店舗の公式情報を確認のうえ、順次掲載します。
  </p>

  <h2>比較記事</h2>
  <ul>
    {articles.map((a) => (
      <li>
        {a.title} <span class="coming-soon">（{a.status}）</span>
      </li>
    ))}
  </ul>

  <h2>このサイトについて</h2>
  <p>
    福岡市在住の運営者が、実際に店舗を訪問して設備を確認したうえで情報をまとめています。
    料金・営業時間などの可変情報は変更される場合があるため、利用前に各店舗の公式サイトで最新情報をご確認ください。
  </p>
</BaseLayout>
